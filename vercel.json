{
  "version": 2,
  "builds": [
    { "src": "index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "index.js" },
    { "src": "/auto-login", "dest": "index.js" },
    { "handle": "filesystem" },
    { "src": "/staff(.*)", "dest": "staff-dashboard.html" },
    { "src": "/student(.*)", "dest": "student-dashboard.html" },
    { "src": "/worker(.*)", "dest": "worker-dashboard.html" },
    { "src": "/guard(.*)", "dest": "guard-dashboard.html" },
    { "src": "/(users|subjects|timetable|notices|blueprint|issues)", "dest": "admin-dashboard.html" },
    { "src": "/(.*)", "dest": "index.js" }
  ]
}
